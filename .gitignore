# --- Pipeline data (mirrors the R project: data/ is gitignored) ---
data/
!data/.gitkeep

# --- Checkpoints & scratch ---
.checkpoints/
*.out
*.log
scratch/

# --- Golden parity fixtures (large; regenerated from R) ---
tests/golden/**/*.tsv
tests/golden/**/*.xlsx
tests/golden/**/*.parquet

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*~

# --- Nextcloud sync artifacts ---
*.sync-conflict-*
~$*
