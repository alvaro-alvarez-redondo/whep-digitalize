# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.so

# --- Virtual environments ---
.venv/
venv/
env/

# --- Tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- uv ---
# uv.lock IS committed (reproducible installs); the environment is not.

# --- Pipeline data (mirrors the R project: data/ is gitignored) ---
data/
!data/.gitkeep

# --- Checkpoints & scratch ---
.checkpoints/
*.out
*.log
scratch/

# --- Golden parity outputs (regenerated from R via tests/parity/capture.py; never committed) ---
# The frozen INPUT fixtures under tests/fixtures/ ARE committed; only the R-derived outputs
# here are ignored (any format: .json/.tsv/.parquet/.xlsx).
tests/golden/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*~

# --- Nextcloud sync artifacts ---
*.sync-conflict-*
~$*
